# ─────────────────────────────────────────────────────────────────────────────
# vnsir-prod — Environment Variables
# Task 1.1.5: Supabase project provisioning
#
# Copy this file to .env.local (never commit .env.local).
# All SUPABASE_* vars can be found in the Supabase dashboard under
# Project Settings → API.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase project ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Resend SMTP (magic links & transactional email) ───────────────────────────
# Create an API key at https://resend.com/api-keys with "Sending access".
# The SMTP user is always "resend"; the password is your API key.
#
# In the Supabase dashboard:
#   Authentication → Settings → SMTP Settings
#     Host:       smtp.resend.com
#     Port:       465
#     Username:   resend
#     Password:   <RESEND_API_KEY>
#     Sender name: vnsir
#     Sender email: noreply@<VNSIR_FROM_DOMAIN>
#
SUPABASE_AUTH_SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
VNSIR_FROM_DOMAIN=yourdomain.com

# ── Storage (informational — bucket limits are set in migration) ───────────────
# reports bucket: private,  50 MB per-file limit
# slides  bucket: public,   10 MB per-file limit
